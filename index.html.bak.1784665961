html body { background: rgb(246, 248, 251); } html { font-size: 100%; }

@keyframes mit-caret{0%,100%{border-color:transparent}50%{border-color:#1A1F2B}}
.mit-typewriter{display:inline-block;overflow:hidden;white-space:nowrap;border-right:2px solid #1A1F2B;animation:mit-caret 0.8s step-end infinite}
.mit-card-reveal{opacity:0 !important;transform:translateX(40px) scale(0.95) !important;transition:opacity .6s cubic-bezier(.22,1,.36,1), transform .6s cubic-bezier(.22,1,.36,1) !important}
.mit-card-reveal.mit-visible{opacity:1 !important;transform:translateX(0) scale(1) !important}

/* Mobile Telegram mock animation */
.m-tg-user{opacity:0;transform:translateY(10px);transition:opacity .4s ease,transform .4s ease}
.m-tg-user.m-visible{opacity:1;transform:translateY(0)}
.m-tg-bot1{opacity:0;transform:translateY(10px);transition:opacity .4s ease,transform .4s ease}
.m-tg-bot1.m-visible{opacity:1;transform:translateY(0)}
.m-tg-bot2{opacity:0;transform:translateY(10px);transition:opacity .4s ease,transform .4s ease}
.m-tg-bot2.m-visible{opacity:1;transform:translateY(0)}
.m-tg-card{opacity:0;transform:translateX(20px) scale(0.9);transition:opacity .5s cubic-bezier(.22,1,.36,1),transform .5s cubic-bezier(.22,1,.36,1)}
.m-tg-card.m-visible{opacity:1;transform:translateX(0) scale(1)}
.m-tg-input{opacity:0;transform:translateY(10px);transition:opacity .4s ease,transform .4s ease}
.m-tg-input.m-visible{opacity:1;transform:translateY(0)}
@media (prefers-reduced-motion:reduce){.m-tg-user,.m-tg-bot1,.m-tg-bot2,.m-tg-card,.m-tg-input{opacity:1!important;transform:none!important}}
.mit-fade{opacity:0 !important;transition:opacity .8s cubic-bezier(.22,1,.36,1), transform .8s cubic-bezier(.22,1,.36,1) !important;transform:translateY(30px) !important}
.mit-fade.mit-visible{opacity:1 !important;transform:translateY(0) !important}
@keyframes mit-icon-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
.mit-float{animation:mit-icon-float 3s ease-in-out infinite}
.mit-mit-faq-answer{box-sizing:border-box;width:100%}
.mit-mit-faq-answer.open{max-height:240px !important;opacity:1 !important;padding-top:12px !important}
[data-mit-name="FAQ Item"]{cursor:pointer}
@media (prefers-reduced-motion:reduce){.mit-fade,.mit-card-reveal,.mit-float{opacity:1 !important;transform:none !important;animation:none !important}}

.mit-faq-item{box-sizing:border-box}
.mit-faq-item:hover{box-shadow:0 8px 24px rgba(26,31,43,.06)}
.mit-faq-item.open .mit-faq-plus{transform:rotate(45deg)}
.mit-faq-item.open .mit-faq-answer{max-height:220px !important;opacity:1 !important;padding-top:10px !important}


.mit-faq-item.open{z-index:30 !important}
.mit-faq-item.open .mit-faq-row{border-radius:16px 16px 0 0}

/* === DESKTOP V2 FIXES === */
/* Форма выше FAQ через order (без перемещения HTML) */
.mit-desktop .mit-fy3r39 { padding-bottom: 0 !important; }
.mit-desktop .mit-vk5liw { order: 2 !important; }
.mit-desktop .mit-1s3dbzb { order: 1 !important; }
/* FAQ Grid: 1 колонка вместо 2 */
.mit-desktop .mit-1eowo8l {
  grid-template-columns: 1fr !important;
  max-width: 800px !important;
}
/* Уменьшить padding-bottom только у футера */
.mit-desktop .mit-iws7i4 { padding-bottom: 0 !important; }
</style>
<style>

/* === RESPONSIVE — v2.1: scale + mobile === */

/* Tablet (769-1199px): scale desktop to fit viewport */
@media (min-width: 769px) and (max-width: 1199px) {
      html, body { overflow-x: hidden; margin: 0; padding: 0; }
      #main { transform-origin: top center; transform: scale(calc((100vw - 40px) / 1200)); width: 1200px; margin: 0 auto; overflow: hidden; }
    }

/* Desktop (≥1200px): proportional scale for wider screens */
@media (min-width: 1200px) {
      html, body { overflow-x: hidden; margin: 0; padding: 0; }
      #main { transform-origin: top center; transform: scale(calc(100vw / 1200)); width: 1200px; margin: 0 auto; overflow: hidden; }
    }

/* Mobile (≤768px): hide desktop, show mobile version */
@media (max-width: 768px) {
  #main {
    display: none !important;
  }
  .mobile-version {
    display: block !important;
  }
}

/* Desktop (≥769px): hide mobile version */
@media (min-width: 769px) {
  .mobile-version {
    display: none !important;
  }
}

</style>
<style>
/* === ADAPTIVE + FORM OVERRIDES FOR V1 === */

/* Desktop: limit max width, center with side margins */
@media (min-width: 1200px) {
  #main {
    max-width: 1200px;
    margin: 0 auto;
    overflow: hidden;
  }
}

/* Tablet scaling for desktop layout — v3: dynamic scale, no horizontal scroll */
@media (max-width: 1199px) and (min-width: 769px) {
  html, body {
    overflow-x: hidden;
    margin: 0;
    padding: 0;
  }
  #main {
    transform-origin: top center;
    transform: scale(calc((100vw - 40px) / 1200));
    width: 1200px;
    margin: 0 auto;
    overflow: hidden;
  }
}

/* Mobile version entrance animations */
.mobile-version .animate-in {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .6s ease, transform .6s ease;
}
.mobile-version .animate-in.visible {
  opacity: 1;
  transform: translateY(0);
}

/* Mobile form status messages */
#form-status-mobile {
  font-size: 13px;
  margin-top: 10px;
  text-align: center;
  min-height: 18px;
}
#form-status-mobile.success { color: #22c55e; }
#form-status-mobile.error { color: #dc2626; }
</style>
</head>
<body>
<div class="mobile-version" id="mobile-version" style="display:none;font-family:'Geist',-apple-system,BlinkMacSystemFont,sans-serif;background:#F5F7FA;min-height:100vh;color:#1A1F2B;">
<!-- ===== MOBILE NAV ===== -->
<nav style="display:flex;justify-content:space-between;align-items:center;padding:14px 16px;background:#fff;border-bottom:1px solid #e1e8f2;position:sticky;top:0;z-index:100;box-shadow:0 1px 4px rgba(0,0,0,0.04);">
<div style="display:flex;align-items:center;gap:8px;">
<img alt="МИТ" src="logo.svg" style="width:34px;height:34px;border-radius:8px;display:block;flex-shrink:0;object-fit:cover;" width="34" height="34"/>
<span style="font-weight:700;font-size:16px;color:#1A1F2B;">МИТ ассистент</span>
</div>
<a href="#lead-form-mobile" style="background:#2aabee;color:#fff;padding:10px 16px;border-radius:10px;text-decoration:none;font-weight:600;font-size:13px;">Запустить</a>
</nav>
<!-- ===== HERO ===== -->
<section style="padding:36px 16px 28px;text-align:center;">
<div style="display:inline-block;background:#2aabee14;border:1px solid #2aabee33;color:#1685C7;padding:6px 14px;border-radius:20px;font-size:13px;font-weight:600;margin-bottom:16px;">AI-агент в Telegram</div>
<h1 style="font-size:30px;font-weight:700;line-height:1.15;margin:0 0 10px;color:#1A1F2B;">Персональный AI-ассистент в Telegram для порядка в работе</h1>
<p style="font-size:15px;color:#5E6B7F;line-height:1.5;margin:0 0 24px;">МИТ берёт рутину на себя: держит контекст, выполняет задачи и напоминает о важном.</p>
<div style="display:flex;flex-direction:column;gap:10px;align-items:center;">
<a href="#lead-form-mobile" style="background:#2aabee;color:#fff;padding:14px 32px;border-radius:12px;text-decoration:none;font-weight:700;font-size:15px;width:100%;max-width:320px;display:block;text-align:center;box-shadow:0 8px 24px #2aabee2e;">Запустить МИТ Ассистент</a>
<a href="#capabilities-mobile" style="color:#1A1F2B;text-decoration:none;font-size:14px;font-weight:600;padding:10px;">Посмотреть возможности</a>
</div>
</section>
<!-- ===== TELEGRAM MOCK ===== -->
<section style="padding:0 16px 40px;">
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:24px;overflow:hidden;max-width:380px;margin:0 auto;box-shadow:0 16px 48px rgba(26,31,43,0.08);">
<!-- Chat Header -->
<div style="background:#f6f8fb;padding:12px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #e1e8f2;">
<img alt="МИТ" height="36" src="logo.svg" style="width:36px;height:36px;border-radius:50%;display:block;flex-shrink:0;" width="36"/>
<div style="flex:1;">
<div style="font-weight:700;font-size:14px;color:#1A1F2B;">МИТ</div>
<div style="font-size:11px;color:#8EA1B2;">AI-агент · 24/7</div>
</div>
<svg height="20" style="flex-shrink:0;" viewbox="0 0 24 24" width="20"><circle cx="12" cy="5" fill="#8EA1B2" r="1.5"></circle><circle cx="12" cy="12" fill="#8EA1B2" r="1.5"></circle><circle cx="12" cy="19" fill="#8EA1B2" r="1.5"></circle></svg>
</div>
<!-- Messages -->
<div style="padding:14px;">
<div class="m-tg-user" style="background:#f0f4f8;border-radius:14px 14px 14px 4px;padding:10px 14px;margin-bottom:8px;font-size:13px;font-weight:500;color:#1A1F2B;max-width:88%;line-height:1.35;">Подготовь отчёт по продажам за апрель, сохрани в папку «Отчёты», поставь напоминание и создай встречу в календаре.</div>
<div class="m-tg-bot1" style="background:#2aabee;border-radius:14px 14px 4px 14px;padding:10px 14px;margin-bottom:8px;font-size:13px;font-weight:700;color:#fff;max-width:88%;margin-left:auto;">Понял. Выполняю план:</div>
<div class="m-tg-bot2" style="background:#2aabee;border-radius:14px 14px 4px 14px;padding:10px 14px;margin-bottom:10px;font-size:12px;font-weight:500;color:rgba(255,255,255,0.9);max-width:88%;margin-left:auto;line-height:1.55;">✓ Анализ данных по продажам<br/>✓ Формирование отчёта<br/>✓ Сохранение файла<br/>✓ Напоминание<br/>✓ Встреча в календаре</div>
<!-- Result Cards -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px;overflow:hidden;">
<div class="m-tg-card" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;padding:10px 12px;display:flex;flex-direction:column;gap:2px;min-width:0;overflow:hidden;"><div style="display:flex;align-items:center;gap:6px;font-size:11px;font-weight:600;color:#1A1F2B;"><span style="color:#22c55e;font-size:13px;flex-shrink:0;">✓</span><span>Встреча создана</span></div><div style="font-size:9px;font-weight:500;color:#5E6B7F;padding-left:17px;">Сегодня, 10:00–11:00</div></div>
<div class="m-tg-card" style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:12px;padding:10px 12px;display:flex;flex-direction:column;gap:2px;min-width:0;overflow:hidden;"><div style="display:flex;align-items:center;gap:6px;font-size:11px;font-weight:600;color:#1A1F2B;"><span style="font-size:13px;flex-shrink:0;">📎</span><span>Файл сохранён</span></div><div style="font-size:9px;font-weight:500;color:#5E6B7F;padding-left:19px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Отчёт_Апрель_2024.pdf</div></div>
<div class="m-tg-card" style="background:#fefce8;border:1px solid #fef08a;border-radius:12px;padding:10px 12px;display:flex;flex-direction:column;gap:2px;min-width:0;overflow:hidden;"><div style="display:flex;align-items:center;gap:6px;font-size:11px;font-weight:600;color:#1A1F2B;"><span style="font-size:13px;flex-shrink:0;">🔔</span><span>Напоминание</span></div><div style="font-size:9px;font-weight:500;color:#5E6B7F;padding-left:19px;">Завтра, 09:50</div></div>
<div class="m-tg-card" style="background:linear-gradient(135deg,#0d6b6b,#2aabee);border-radius:12px;padding:10px 12px;display:flex;flex-direction:column;justify-content:center;gap:2px;min-width:0;overflow:hidden;"><div style="font-size:13px;font-weight:800;color:#fff;">Продажи: +24%</div><div style="font-size:9px;font-weight:500;color:rgba(255,255,255,0.78);">Рост к прошлому месяцу</div></div>
</div>
<!-- Input -->
<div class="m-tg-input" style="margin-top:10px;background:#f6f8fb;border:1px solid #e1e8f2;border-radius:14px;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;">
<span style="font-size:12px;color:#8EA1B2;">Напишите сообщение…</span>
<div style="width:24px;height:24px;background:#2aabee;border-radius:50%;"></div>
</div>
</div>
</div>
</section>
<!-- ===== ADVANTAGES (4 cards) ===== -->
<section style="padding:0 16px 40px;">
<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:18px;padding:18px 14px;box-shadow:0 4px 16px rgba(26,31,43,0.04);">
<div style="width:36px;height:36px;background:#2aabee14;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">
<svg height="18" viewbox="0 0 24 24" width="18"><circle cx="12" cy="12" fill="none" r="9" stroke="#2aabee" stroke-width="2"></circle><circle cx="12" cy="8" fill="#2aabee" r="2"></circle><path d="M8 18c0-2.2 1.8-4 4-4s4 1.8 4 4" fill="none" stroke="#2aabee" stroke-linecap="round" stroke-width="2"></path></svg>
</div>
<div style="font-weight:700;font-size:16px;margin-bottom:4px;color:#1A1F2B;">Контекст</div>
<div style="font-size:13px;color:#5E6B7F;line-height:1.45;">Задачи, диалоги и договорённости остаются в памяти.</div>
</div>
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:18px;padding:18px 14px;box-shadow:0 4px 16px rgba(26,31,43,0.04);">
<div style="width:36px;height:36px;background:#7a3cff14;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">
<svg height="18" viewbox="0 0 24 24" width="18"><path d="M4 4h16v2H4zm0 6h16v2H4zm0 6h10v2H4z" fill="#7a3cff"></path></svg>
</div>
<div style="font-weight:700;font-size:16px;margin-bottom:4px;color:#1A1F2B;">Рутина</div>
<div style="font-size:13px;color:#5E6B7F;line-height:1.45;">Повторяющиеся действия выполняются без вашего участия.</div>
</div>
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:18px;padding:18px 14px;box-shadow:0 4px 16px rgba(26,31,43,0.04);">
<div style="width:36px;height:36px;background:#22c55e14;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">
<svg height="18" viewbox="0 0 24 24" width="18"><circle cx="12" cy="12" fill="none" r="9" stroke="#22c55e" stroke-width="2"></circle><polyline fill="none" points="8,12 11,15 16,9" stroke="#22c55e" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></polyline></svg>
</div>
<div style="font-weight:700;font-size:16px;margin-bottom:4px;color:#1A1F2B;">Контроль</div>
<div style="font-size:13px;color:#5E6B7F;line-height:1.45;">Важное не теряется и приходит вовремя.</div>
</div>
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:18px;padding:18px 14px;box-shadow:0 4px 16px rgba(26,31,43,0.04);">
<div style="width:36px;height:36px;background:#0d6b6b14;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">
<svg height="18" viewbox="0 0 24 24" width="18"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" fill="none" stroke="#0d6b6b" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
</div>
<div style="font-weight:700;font-size:16px;margin-bottom:4px;color:#1A1F2B;">Навыки</div>
<div style="font-size:13px;color:#5E6B7F;line-height:1.45;">МИТ учится работать по вашим правилам.</div>
</div>
</div>
</section>
<!-- ===== CAPABILITIES (6 bento cards) ===== -->
<section id="capabilities-mobile" style="padding:0 16px 40px;">
<div style="text-align:center;margin-bottom:24px;">
<h2 style="font-size:24px;font-weight:700;margin:0 0 8px;color:#1A1F2B;">Что уже умеет МИТ ассистент</h2>
<p style="font-size:14px;color:#5E6B7F;line-height:1.5;margin:0;">Базовые навыки уже внутри: задачи, календарь, напоминания, идеи, документы, таблицы и база знаний работают прямо в Telegram.</p>
</div>
<div style="display:flex;flex-direction:column;gap:10px;">
<!-- Calendar -->
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:20px;padding:18px;box-shadow:0 8px 24px rgba(26,31,43,0.05);">
<div style="display:flex;gap:8px;margin-bottom:14px;">
<div style="background:#f6f8fb;border:1px solid #e1e8f2;border-radius:12px;padding:8px 12px;text-align:center;font-weight:800;font-size:18px;color:#8EA1B2;">09</div>
<div style="background:#2aabee;border-radius:12px;padding:8px 12px;text-align:center;font-weight:800;font-size:22px;color:#fff;">10</div>
<div style="background:#f6f8fb;border:1px solid #e1e8f2;border-radius:12px;padding:8px 12px;text-align:center;font-weight:800;font-size:18px;color:#2aabee;">11</div>
<div style="background:#f6f8fb;border:1px solid #e1e8f2;border-radius:12px;padding:8px 12px;display:flex;flex-direction:column;justify-content:center;">
<div style="font-weight:800;font-size:12px;color:#1A1F2B;">Встреча создана</div>
<div style="font-size:10px;color:#5E6B7F;">Сегодня · 10:00–11:00</div>
</div>
</div>
<div style="font-weight:800;font-size:18px;color:#1A1F2B;margin-bottom:4px;">Календарь</div>
<div style="font-size:13px;color:#5E6B7F;line-height:1.45;">Создаёт встречи, переносит события и показывает расписание.</div>
</div>
<!-- Tasks -->
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:20px;padding:18px;box-shadow:0 8px 24px rgba(26,31,43,0.05);">
<div style="margin-bottom:14px;">
<div style="font-weight:700;font-size:13px;color:#1685C7;margin-bottom:8px;">Рабочий план · сегодня</div>
<div style="font-weight:600;font-size:14px;color:#1A1F2B;margin-bottom:4px;">✓ Отчёт по продажам · 82%</div>
<div style="font-weight:600;font-size:14px;color:#1A1F2B;margin-bottom:8px;">✓ Согласовать встречу · 10:00</div>
<div style="background:#e1e8f2;border-radius:999px;height:8px;overflow:hidden;"><div style="background:linear-gradient(90deg,#2aabee,#7a3cff);height:8px;width:82%;border-radius:999px;"></div></div>
</div>
<div style="font-weight:800;font-size:18px;color:#1A1F2B;margin-bottom:4px;">Задачи</div>
<div style="font-size:13px;color:#5E6B7F;line-height:1.45;">Создаёт задачи, фиксирует сроки и помогает контролировать выполнение.</div>
</div>
<!-- Documents -->
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:20px;padding:18px;box-shadow:0 8px 24px rgba(26,31,43,0.05);">
<div style="margin-bottom:14px;display:flex;align-items:flex-start;gap:10px;">
<div style="width:36px;height:36px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
<svg height="18" viewBox="0 0 24 24" width="18"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" fill="none" stroke="#2aabee" stroke-width="2" stroke-linejoin="round"/><path d="M14 2v6h6" fill="none" stroke="#2aabee" stroke-width="2" stroke-linejoin="round"/><text x="8" y="18" fill="#2aabee" font-size="7" font-weight="bold">PDF</text></svg>
</div>
<div style="flex:1;min-width:0;">
<div style="font-weight:700;font-size:14px;color:#1A1F2B;margin-bottom:6px;">Отчёт_Апрель.pdf</div>
<div style="background:#eff6ff;border-radius:6px;height:6px;width:70%;margin-bottom:4px;"></div>
<div style="background:#eff6ff;border-radius:6px;height:6px;width:45%;margin-bottom:8px;"></div>
<div style="display:inline-block;background:#2aabee14;border:1px solid #2aabee33;border-radius:8px;padding:4px 10px;font-weight:700;font-size:10px;color:#1685C7;">сохранено в «Отчёты»</div>
</div>
</div>
<div style="font-weight:800;font-size:18px;color:#1A1F2B;margin-bottom:4px;">Документы</div>
<div style="font-size:13px;color:#5E6B7F;line-height:1.45;">Создаёт черновики, сохраняет материалы и помогает найти нужное.</div>
</div>
<!-- Excel / Tables -->
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:20px;padding:18px;box-shadow:0 8px 24px rgba(26,31,43,0.05);">
<div style="display:flex;align-items:flex-end;gap:6px;height:60px;margin-bottom:14px;padding:8px;background:#f6f8fb;border-radius:10px;">

.007 7.169 3.373 5.847 4.061 C 4.526 4.749 2.931 4.645 1.71 3.792 C 0.488 2.939 -0.158 1.478 0.033 0" fill="transparent" height="4.512742367620977px" id="iFPxDs4YB" stroke="var(--1m973uw, rgb(0,0,0))" stroke-dasharray="" stroke-linecap="round" stroke-linejoin="round" stroke-width="var(--js9iwy, 2)" transform="translate(4 17.483)" width="16.000157970756632px"></path><path d="M 4 7.464 C 2.19 7.464 0.605 6.248 0.137 4.499 C -0.332 2.751 0.432 0.905 2 0" fill="transparent" height="7.464px" id="Lubb1O1AI" stroke="var(--1m973uw, rgb(0,0,0))" stroke-dasharray="" stroke-linecap="round" stroke-linejoin="round" stroke-width="var(--js9iwy, 2)" transform="translate(2 10.536)" width="4.000185577272697px"></path><path d="M 3.004 0 C 1.813 0.306 0.829 1.143 0.336 2.27 C -0.157 3.396 -0.105 4.687 0.478 5.77" fill="transparent" height="5.77px" id="iddM66qAg" stroke="var(--1m973uw, rgb(0,0,0))" stroke-dasharray="" stroke-linecap="round" stroke-linejoin="round" stroke-width="var(--js9iwy, 2)" transform="translate(2.999 5.125)" width="3.003908291565727px"></path></svg>
<svg display="block" id="332324033" role="presentation" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M 14 8 C 14 9.105 13.105 10 12 10 L 4.828 10 C 4.298 10 3.789 10.211 3.414 10.586 L 1.212 12.788 C 1.009 12.991 0.704 13.052 0.438 12.942 C 0.173 12.832 0 12.573 0 12.286 L 0 2 C 0 0.895 0.895 0 2 0 L 12 0 C 13.105 0 14 0.895 14 2 Z" fill="transparent" height="12.995929119583728px" id="SQiLgBMM_" stroke="var(--1m973uw, rgb(0,0,0))" stroke-dasharray="" stroke-linecap="round" stroke-linejoin="round" stroke-width="var(--js9iwy, 2)" transform="translate(2 2)" width="14px"></path><path d="M 12 0 C 13.105 0 14 0.895 14 2 L 14 12.286 C 14 12.573 13.827 12.832 13.562 12.942 C 13.296 13.052 12.991 12.991 12.788 12.788 L 10.586 10.586 C 10.211 10.211 9.702 10 9.172 10 L 2 10 C 0.895 10 0 9.105 0 8 L 0 7" fill="transparent" height="12.995929119583732px" id="s4tTBBM1k" stroke="var(--1m973uw, rgb(0,0,0))" stroke-dasharray="" stroke-linecap="round" stroke-linejoin="round" stroke-width="var(--js9iwy, 2)" transform="translate(8 9)" width="14px"></path></svg>

7px 10px;--mit-text-background-radius:999px">команда</mark></p></div><div class="mit-ukq0vs" data-mit-component-type="RichTextContainer" style="transform:none"><p class="mit-text" dir="auto" style='--font-selector:R0Y7R2Vpc3QtNzAw;--mit-font-family:"Geist", "Geist Placeholder", sans-serif;--mit-font-size:12px;--mit-font-weight:700;--mit-line-height:1em;--mit-text-color:#0D6B6B'><mark class="mit-text" style="--mit-text-background-color:rgba(34,197,94,0.10);--mit-text-background-padding:7px 10px 7px 10px;--mit-text-background-radius:999px">формат</mark></p></div></div><div class="mit-yeqke4" data-mit-component-type="RichTextContainer" style="transform:none"><p class="mit-text" dir="auto" style='--font-selector:R0Y7R2Vpc3QtODAw;--mit-font-family:"Geist", "Geist Placeholder", sans-serif;--mit-font-size:24px;--mit-font-weight:800;--mit-line-height:1.08em;--mit-text-color:rgb(26, 31, 43)'>Повторяющаяся работа</p></div><div class="mit-19426z4" data-mit-component-type="RichTextContainer" style="transform:none"><p class="mit-text" dir="auto" style='--font-selector:R0Y7R2Vpc3QtcmVndWxhcg==;--mit-font-family:"Geist", "Geist Placeholder", sans-serif;--mit-font-size:14px;--mit-line-height:1.45em;--mit-text-color:rgb(94, 107, 127)'>То, что каждую неделю приходится собирать вручную: сообщения, файлы, таблицы, отчёты и чек-листы.</p></div></div><div class="mit-93lzdv" data-border="true" data-mit-name="Skill Assembly"><div class="mit-uwy9lo" data-mit-component-type="RichTextContainer" style="transform:none"><p class="mit-text" dir="auto" style='--font-selector:R0Y7R2Vpc3QtODAw;--mit-font-family:"Geist", "Geist Placeholder", sans-serif;--mit-font-size:13px;--mit-font-weight:800;--mit-line-height:1em;--mit-text-color:#7A3CFF'>сборка навыка</p></div><div class="mit-2pqazd" data-mit-name="Skill Saved Scene"><div class="mit-1kit0v0" data-border="true" data-mit-name="MIT Skill Core"><div class="mit-11xwu5s" data-mit-name="MIT Logo"><div data-mit-background-image-wrapper="true" style="posi
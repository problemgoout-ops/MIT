</div><div class="mit-mit-faq-answer" style="max-height:0;overflow:hidden;opacity:0;padding:0 22px;transform:none;transition:max-height .35s ease,opacity .35s ease,padding .35s ease;"><p style="font-family:&#39;Geist&#39;,sans-serif;font-size:14px;font-weight:500;line-height:1.55em;color:#5E6B7F;margin:0;padding:0 0 14px;">Да. Telegram, почта, календарь, базы знания, API и внутренние системы — подключаем под ваши задачи.</p></div>
<script>
(function() {
  // --- Mobile form handler ---
  const mobileForm = document.getElementById('mobile-form');
  if (mobileForm) {
    const status = document.createElement('div');
    status.id = 'form-status-mobile';
    mobileForm.appendChild(status);

    mobileForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      const inputs = mobileForm.querySelectorAll('input[required], textarea[required]');
      const data = {};
      let valid = true;
      inputs.forEach(function(input) {
        const key = input.name || input.placeholder.toLowerCase().replace(/[^a-z]/g, '');
        data[key] = input.value.trim();
        if (!data[key]) valid = false;
      });
      // Also include non-required fields
      const allInputs = mobileForm.querySelectorAll('input, textarea');
      allInputs.forEach(function(input) {
        if (!input.required) {
          const key = input.name || input.placeholder.toLowerCase().replace(/[^a-z]/g, '');
          data[key] = input.value.trim();
        }
      });
      if (!valid) {
        status.className = 'error';
        status.textContent = 'Заполните все обязательные поля (отмечены *)';
        return;
      }

      // Validate email format
      var emailInput = mobileForm.querySelector('input[name="email"]');
      if (emailInput && emailInput.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim())) {
        status.className = 'error';
        status.textContent = 'Укажите корректный email';
        return;
      }

      // Validate Telegram format
      var tgInput = mobileForm.querySelector('input[name="telegram"]');
      if (tgInput && tgInput.value.trim() && !/^@?[a-zA-Z][a-zA-Z0-9_]{4,31}$/.test(tgInput.value.trim())) {
        status.className = 'error';
        status.textContent = 'Telegram: формат @username (латиница, цифры, подчёркивание, от 5 символов)';
        return;
      }

      // Validate name fields (letters only)
      var nameFields = ['lastName', 'firstName'];
      for (var ni = 0; ni < nameFields.length; ni++) {
        var nf = mobileForm.querySelector('input[name="' + nameFields[ni] + '"]');
        if (nf && nf.value.trim() && !/^[A-Za-zА-Яа-яЁё\- ]{2,}$/.test(nf.value.trim())) {
          status.className = 'error';
          status.textContent = 'Имя и фамилия: только буквы, дефис и пробел, минимум 2 символа';
          return;
        }
      }

      // Validate task min length
      var taskInput = mobileForm.querySelector('textarea[name="task"]');
      if (taskInput && taskInput.value.trim() && taskInput.value.trim().length < 10) {
        status.className = 'error';
        status.textContent = 'Опишите задачу подробнее (минимум 10 символов)';
        return;
      }

      status.className = '';
      status.textContent = 'Отправка…';
      const btn = mobileForm.querySelector('button');
      btn.disabled = true;

      try {
        const res = await fetch('/api/leads/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error('Server error');
        status.className = 'success';
        status.textContent = 'Заявка отправлена. Мы свяжемся с вами в Telegram.';
        mobileForm.reset();
      } catch (err) {
        status.className = 'error';
        status.textContent = 'Не удалось отправить. Попробуйте позже или напишите нам в Telegram.';
      } finally {
        btn.disabled = false;
      }
    });
  }

  // --- Desktop form handler ---
  var desktopForm = document.querySelector('#lead-form form[data-mit-name="Application Form"]');
  if (desktopForm) {
    var desktopStatus = document.createElement('div');
    desktopStatus.id = 'form-status-desktop';
    desktopStatus.style.cssText = 'font-size:13px;text-align:center;min-height:18px;margin-top:8px;';
    desktopForm.appendChild(desktopStatus);

    desktopForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      var requiredInputs = desktopForm.querySelectorAll('input[required], textarea[required]');
      var data = {};
      var valid = true;
      requiredInputs.forEach(function(input) {
        var key = input.name;
        data[key] = input.value.trim();
        if (!data[key]) valid = false;
      });
      // Also include non-required fields
      var allInputs = desktopForm.querySelectorAll('input:not([aria-hidden]), textarea');
      allInputs.forEach(function(input) {
        if (!input.required && input.name && input.name !== 'website' && input.name !== 'company' && input.name !== 'message' && input.name !== 'subject' && input.name !== 'title' && input.name !== 'description' && input.name !== 'feedback' && input.name !== 'notes' && input.name !== 'details' && input.name !== 'remarks' && input.name !== 'comments') {
          data[input.name] = input.value.trim();
        }
      });
      if (!valid) {
        desktopStatus.className = '';
        desktopStatus.style.color = '#dc2626';
        desktopStatus.textContent = 'Заполните все обязательные поля (отмечены *)';
        return;
      }

      // Validate email format
      var emailInput = desktopForm.querySelector('input[name="email"]');
      if (emailInput && emailInput.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim())) {
        desktopStatus.className = '';
        desktopStatus.style.color = '#dc2626';
        desktopStatus.textContent = 'Укажите корректный email';
        return;
      }

      // Validate Telegram format
      var tgInput = desktopForm.querySelector('input[name="telegram"]');
      if (tgInput && tgInput.value.trim() && !/^@?[a-zA-Z][a-zA-Z0-9_]{4,31}$/.test(tgInput.value.trim())) {
        desktopStatus.className = '';
        desktopStatus.style.color = '#dc2626';
        desktopStatus.textContent = 'Telegram: формат @username (латиница, цифры, подчёркивание, от 5 символов)';
        return;
      }

      // Validate name fields (letters only)
      var nameFields = ['last_name', 'first_name'];
      for (var ni = 0; ni < nameFields.length; ni++) {
        var nf = desktopForm.querySelector('input[name="' + nameFields[ni] + '"]');
        if (nf && nf.value.trim() && !/^[A-Za-zА-Яа-яЁё\- ]{2,}$/.test(nf.value.trim())) {
          desktopStatus.className = '';
          desktopStatus.style.color = '#dc2626';
          desktopStatus.textContent = 'Имя и фамилия: только буквы, дефис и пробел, минимум 2 символа';
          return;
        }
      }

      // Validate task min length
      var taskInput = desktopForm.querySelector('textarea[name="task"]');
      if (taskInput && taskInput.value.trim() && taskInput.value.trim().length < 10) {
        desktopStatus.className = '';
        desktopStatus.style.color = '#dc2626';
        desktopStatus.textContent = 'Опишите задачу подробнее (минимум 10 символов)';
        return;
      }

      desktopStatus.style.color = '#5E6B7F';
      desktopStatus.textContent = 'Отправка…';
      var btn = desktopForm.querySelector('button');
      if (btn) btn.disabled = true;

      try {
        var res = await fetch('/api/leads/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error('Server error');
        desktopStatus.style.color = '#22c55e';
        desktopStatus.textContent = 'Заявка отправлена. Мы свяжемся с вами в Telegram.';
        desktopForm.reset();
      } catch (err) {
        desktopStatus.style.color = '#dc2626';
        desktopStatus.textContent = 'Не удалось отправить. Попробуйте позже или напишите нам в Telegram.';
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  }

  // --- Entrance animations for mobile sections ---
  const mobileRoot = document.getElementById('mobile-version');
  if (mobileRoot) {
    const sections = mobileRoot.querySelectorAll('section, nav');
    sections.forEach(function(el) { el.classList.add('animate-in'); });

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    sections.forEach(function(el) { observer.observe(el); });
  }

  // --- Dynamic scaling for all desktop viewports ---
  function adjustDesktopScale() {
    const w = window.innerWidth;
    const main = document.getElementById('main');
    if (!main) return;
    if (w >= 769) {
      // Cap scale at 1.0 — don't stretch beyond 1200px
      const rawScale = w >= 1200 ? 1.0 : Math.max(0.6, (w - 40) / 1200);
      main.style.transform = 'scale(' + rawScale.toFixed(3) + ')';
      main.style.width = '1200px';
      main.style.margin = '0 auto';
      main.style.transformOrigin = 'top center';
    } else {
      main.style.transform = '';
      main.style.width = '';
      main.style.margin = '';
      main.style.transformOrigin = '';
    }
  }
  adjustDesktopScale();
  window.addEventListener('resize', adjustDesktopScale);
})();

(function(){
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  (function(){
    var scene = document.querySelector('[data-mit-name="Telegram Product Scene"]');
    if (!scene) return;
    var userReq = scene.querySelector('[data-mit-name="User Request"]');
    var userText = userReq ? userReq.querySelector('.mit-text') : null;
    var execPlan = scene.querySelector('[data-mit-name="Execution Plan"]');
    var execTexts = execPlan ? execPlan.querySelectorAll('.mit-text') : [];
    var header = execTexts[0] || null;
    var checklistEl = execTexts[1] || null;
    var headerOriginal = header ? header.textContent.trim() : '';
    var checklistOriginal = checklistEl ? checklistEl.textContent.trim() : '';
    var cards = Array.from(scene.querySelectorAll('[data-mit-name="Meeting Created"], [data-mit-name="File Saved"], [data-mit-name="Reminder"], [data-mit-name="Sales Growth"]'));
    cards.forEach(function(c){ c.classList.add('mit-card-reveal'); });
    if (header) header.textContent = '';
    if (checklistEl) checklistEl.textContent = '';
    if (execPlan) execPlan.style.opacity = '0';
    function revealCards(){ cards.forEach(function(c,i){ setTimeout(function(){ c.classList.add('mit-visible'); }, i*180); }); }
    function typewrite(el, txt, speed, cb){
      if (!el) { if (cb) cb(); return; }
      el.textContent = ''; el.classList.add('mit-typewriter');
      var i=0, iv = setInterval(function(){
        el.textContent = txt.substring(0, i+1); i++;
        if (i >= txt.length){ clearInterval(iv); if (cb) cb(); }
      }, speed);
    }
    if (userText) {
      typewrite(userText, userText.textContent.trim(), 32, function(){
        userText.style.borderRight = 'none';
        if (execPlan) { execPlan.style.transition='none'; execPlan.style.opacity='1'; }
        typewrite(header, headerOriginal, 28, function(){
          if (header) header.style.borderRight = 'none';
          if (checklistEl) {
            var items = checklistOriginal.split('✓').map(function(s){return s.trim();}).filter(Boolean);
            checklistEl.textContent = ''; checklistEl.classList.add('mit-typewriter'); checklistEl.style.whiteSpace = 'pre-wrap';
            var shown=[], li=0, iv2 = setInterval(function(){
              shown.push('✓ ' + items[li]); checklistEl.textContent = shown.join('\n'); li++;
              if (li >= items.length){ clearInterval(iv2); checklistEl.style.borderRight='none'; revealCards(); }
            }, 240);
          } else revealCards();
        });
      });
    }
  })();
  (function(){
    var animated = new Set();
    function setReveal(el, delay){
      if (!el || animated.has(el)) return;
      animated.add(el);
      el.style.opacity = '0';
      el.style.transform = 'translateY(36px)';
      el.style.transition = 'opacity .75s cubic-bezier(.22,1,.36,1) ' + delay + 's, transform .75s cubic-bezier(.22,1,.36,1) ' + delay + 's';
    }
    function reveal(el){ el.style.opacity = '1'; el.style.transform = 'translateY(0)'; }
    function observe(els){
      var obs = new IntersectionObserver(function(entries, o){
        entries.forEach(function(e){ if (e.isIntersecting){ reveal(e.target); o.unobserve(e.target); } });
      }, { threshold: 0.05, rootMargin: '0px 0px -60px 0px' });
      els.forEach(function(el){ if (el) obs.observe(el); });
    }
    function stagger(els, base, step){ els.forEach(function(el,i){ setReveal(el, base + i*step); }); observe(els); }
    var sectionNames = ['Navigation','Hero','Advantage Strip','Capabilities','Intermediate CTA','Integrations Hub','Personal Skills','Security and Launch','Pricing','FAQ and Lead Form','Footer'];
    sectionNames.forEach(function(n,i){ var el = document.querySelector('[data-mit-name="' + n + '"]'); if (el) setReveal(el, Math.min(i,8)*0.05); });
    observe(sectionNames.map(function(n){ return document.querySelector('[data-mit-name="' + n + '"]'); }).filter(Boolean));
    var strip = document.querySelector('[data-mit-name="Advantage Strip"]');
    if (strip) stagger(Array.from(strip.querySelectorAll('[data-mit-name]')), 0.1, 0.1);
    var caps = document.querySelector('[data-mit-name="Capabilities"]');
    if (caps) stagger(Array.from(caps.querySelectorAll('[data-mit-name]')), 0.1, 0.08);
    var trust = document.querySelector('[data-mit-name="Trust Row"]');
    if (trust) { stagger(Array.from(trust.querySelectorAll('[data-mit-name]')), 0.1, 0.1); trust.querySelectorAll('svg').forEach(function(s,i){ s.classList.add('mit-float'); s.style.animationDelay = (i*0.4)+'s'; }); }
    var launch = document.querySelector('[data-mit-name="Launch Flow"]');
    if (launch) stagger(Array.from(launch.querySelectorAll('[data-mit-name]')), 0.1, 0.12);
    var faq = document.querySelector('[data-mit-name="FAQ Grid"]');
    if (faq) stagger(Array.from(faq.querySelectorAll('[data-mit-name]')), 0.1, 0.08);
    var skills = document.querySelector('[data-mit-name="Personal Skills"]');
    if (skills) stagger(Array.from(skills.querySelectorAll('[data-mit-name]')), 0.1, 0.12);
    var hub = document.querySelector('[data-mit-name="Integrations Hub"]');
    if (hub){
      var all = [];
      ['Incoming Message','Incoming File','Incoming Document','Incoming Calendar','Mail Source','Knowledge Source'].forEach(function(n){
        var el = hub.querySelector('[data-mit-name="' + n + '"]'); if (el) all.push({el:el, fromX:-120});
      });
      ['Task Output','Summary Output','Skill Output','Meeting and Reminder Output'].forEach(function(n){
        var el = hub.querySelector('[data-mit-name="' + n + '"]'); if (el) all.push({el:el, fromX:120});
      });
      var core = hub.querySelector('[data-mit-name="MIT Core"]'); if (core) all.push({el:core, fromX:0, fromScale:0.85});
      all.forEach(function(item,i){
        if (animated.has(item.el)) return; animated.add(item.el);
        var delay = 0.1 + i*0.06;
        item.el.style.opacity='0';
        item.el.style.transform = 'translateX(' + (item.fromX||0) + 'px) scale(' + (item.fromScale||1) + ')';
        item.el.style.transition = 'opacity .8s cubic-bezier(.22,1,.36,1) ' + delay + 's, transform .8s cubic-bezier(.22,1,.36,1) ' + delay + 's';
      });
      var obs2 = new IntersectionObserver(function(entries, o){
        entries.forEach(function(e){ if (e.isIntersecting){ e.target.style.opacity='1'; e.target.style.transform='translateX(0) scale(1)'; o.unobserve(e.target); } });
      }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
      all.forEach(function(item){ obs2.observe(item.el); });
    }
  })();
  
// Dynamic FAQ from API — replaces hardcoded desktop FAQ items
(function(){
  var faqItems = document.querySelectorAll('.mit-faq-item');
  if (!faqItems.length) return;
  
  fetch('/api/faqs/')
    .then(function(r) { return r.json(); })
    .then(function(items) {
      if (!items.length) return;
      faqItems.forEach(function(faqEl, idx) {
        if (idx >= items.length) { faqEl.style.display = 'none'; return; }
        var row = faqEl.querySelector('.mit-faq-row p');
        var answer = faqEl.querySelector('.mit-faq-answer p');
        if (row) row.textContent = items[idx].question;
        if (answer) answer.textContent = items[idx].answer;
      });
      // Re-bind click handlers after content update
      faqItems.forEach(function(item){
        item.addEventListener('click', function(){
          var isOpen = item.classList.contains('open');
          document.querySelectorAll('.mit-faq-item.open').forEach(function(i){ i.classList.remove('open'); });
          if (!isOpen) item.classList.add('open');
        });
      });
    })
    .catch(function() {
      // Keep hardcoded fallback if API fails
    });
})();

})();

// Mobile Telegram mock animation
(function(){
  var tgSection = document.querySelector('.m-tg-user');
  if (!tgSection) return;
  var tgMock = tgSection.closest('section');
  if (!tgMock) return;
  
  var user = tgMock.querySelector('.m-tg-user');
  var bot1 = tgMock.querySelector('.m-tg-bot1');
  var bot2 = tgMock.querySelector('.m-tg-bot2');
  var cards = Array.from(tgMock.querySelectorAll('.m-tg-card'));
  var input = tgMock.querySelector('.m-tg-input');
  
  var started = false;
  function startAnim(){
    if (started) return; started = true;
    // 1. User message appears
    setTimeout(function(){ if(user) user.classList.add('m-visible'); }, 200);
    // 2. Bot reply "Понял. Выполняю план:"
    setTimeout(function(){ if(bot1) bot1.classList.add('m-visible'); }, 1200);
    // 3. Bot checklist
    setTimeout(function(){ if(bot2) bot2.classList.add('m-visible'); }, 1800);
    // 4. Result cards one by one
    cards.forEach(function(c, i){
      setTimeout(function(){ c.classList.add('m-visible'); }, 2400 + i * 200);
    });
    // 5. Input bar
    setTimeout(function(){ if(input) input.classList.add('m-visible'); }, 2400 + cards.length * 200 + 200);
  }
  
  // Start when scrolled into view
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if (e.isIntersecting) { startAnim(); io.unobserve(e.target); } });
    }, { threshold: 0.3 });
    io.observe(tgMock);
  } else {
    startAnim();
  }
})();
</script>
</body>
</html>
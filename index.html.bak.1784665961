<!-- ===== APPLICATION FORM ===== -->
<section id="lead-form-mobile" style="padding:0 16px 60px;">
<div style="background:#fff;border:1px solid #e1e8f2;border-radius:24px;padding:28px 20px;max-width:420px;margin:0 auto;box-shadow:0 16px 48px rgba(26,31,43,0.08);">
<h2 style="font-size:22px;font-weight:700;text-align:center;margin:0 0 6px;color:#1A1F2B;">Оставить заявку</h2>
<p style="font-size:13px;color:#5E6B7F;text-align:center;margin:0 0 20px;">Мы свяжемся с вами в Telegram</p>
<form id="mobile-form" style="display:flex;flex-direction:column;gap:10px;">
<input name="lastName" onblur="this.style.borderColor='#dce5ef'" onfocus="this.style.borderColor='#2aabee'" placeholder="Фамилия *" required="" pattern="[A-Za-zА-Яа-яЁё\- ]{2,}" minlength="2" title="Только буквы, дефис и пробел, минимум 2 символа" style="padding:12px 14px;border:1px solid #dce5ef;border-radius:12px;font-size:14px;font-family:inherit;background:#f6f8fb;color:#1A1F2B;outline:none;transition:border-color .2s;" type="text"/>
<input name="firstName" onblur="this.style.borderColor='#dce5ef'" onfocus="this.style.borderColor='#2aabee'" placeholder="Имя *" required="" pattern="[A-Za-zА-Яа-яЁё\- ]{2,}" minlength="2" title="Только буквы, дефис и пробел, минимум 2 символа" style="padding:12px 14px;border:1px solid #dce5ef;border-radius:12px;font-size:14px;font-family:inherit;background:#f6f8fb;color:#1A1F2B;outline:none;transition:border-color .2s;" type="text"/>
<input name="telegram" onblur="this.style.borderColor='#dce5ef'" onfocus="this.style.borderColor='#2aabee'" placeholder="Telegram @username *" required="" pattern="@?[a-zA-Z][a-zA-Z0-9_]{4,31}" minlength="5" title="Формат: @username (латиница, цифры, подчёркивание, от 5 символов)" style="padding:12px 14px;border:1px solid #dce5ef;border-radius:12px;font-size:14px;font-family:inherit;background:#f6f8fb;color:#1A1F2B;outline:none;transition:border-color .2s;" type="text"/>
<input name="email" onblur="this.style.borderColor='#dce5ef'" onfocus="this.style.borderColor='#2aabee'" placeholder="Почта *" required="" style="padding:12px 14px;border:1px solid #dce5ef;border-radius:12px;font-size:14px;font-family:inherit;background:#f6f8fb;color:#1A1F2B;outline:none;transition:border-color .2s;" type="email"/>
<textarea name="task" onblur="this.style.borderColor='#dce5ef'" onfocus="this.style.borderColor='#2aabee'" placeholder="Опишите задачу" required="" minlength="10" title="Минимум 10 символов" rows="3" style="padding:12px 14px;border:1px solid #dce5ef;border-radius:12px;font-size:14px;font-family:inherit;background:#f6f8fb;color:#1A1F2B;resize:vertical;outline:none;transition:border-color .2s;"></textarea>
<button style="background:#2aabee;color:#fff;border:none;padding:14px;border-radius:14px;font-weight:700;font-size:15px;cursor:pointer;font-family:inherit;box-shadow:0 8px 24px #2aabee2e;transition:opacity .2s;" type="submit">Отправить заявку</button>
<div id="form-status-mobile" style="font-size:13px;text-align:center;min-height:18px;margin-top:4px;"></div>
</form>
</div>
</section>
<!-- ===== FAQ (dynamic from API) ===== -->
<section style="padding:0 16px 40px;">
<div style="text-align:center;margin-bottom:24px;">
<h2 style="font-size:24px;font-weight:700;margin:0 0 8px;color:#1A1F2B;">Частые вопросы</h2>
</div>
<div id="faq-container" style="display:flex;flex-direction:column;gap:8px;">
<p style="text-align:center;color:#8EA1B2;font-size:14px;">Загрузка вопросов...</p>
</div>
</section>
<script>
(function() {
  var container = document.getElementById('faq-container');
  if (!container) return;
  fetch('/api/faqs/')
    .then(function(r) { return r.json(); })
    .then(function(items) {
      if (!items.length) {
        container.innerHTML = '<p style="text-align:center;color:#8EA1B2;font-size:14px;">Вопросов пока нет</p>';
        return;
      }
      var html = '';
      items.slice(0, 8).forEach(function(item) {
        html += '<details style="background:#fff;border:1px solid #e1e8f2;border-radius:14px;padding:14px 16px;box-shadow:0 2px 8px rgba(26,31,43,0.03);">' +
          '<summary style="font-weight:600;font-size:14px;color:#1A1F2B;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">' +
          item.question + '<span style="font-size:18px;color:#8EA1B2;">+</span></summary>' +
          '<p style="font-size:13px;color:#5E6B7F;margin:10px 0 0;line-height:1.5;">' + item.answer + '</p>' +
          '</details>';
      });
      container.innerHTML = html;
    })
    .catch(function() {
      container.innerHTML = '<p style="text-align:center;color:#8EA1B2;font-size:14px;">Не удалось загрузить вопросы</p>';
    });
})();
</script>


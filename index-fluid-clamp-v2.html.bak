@keyframes mit-caret{0%,100%{border-color:transparent}50%{border-color:#1A1F2B}}
.mit-typewriter{display:inline-block;overflow:hidden;white-space:nowrap;border-right:2px solid #1A1F2B;animation:mit-caret 0.8s step-end infinite}
.mit-card-reveal{opacity:0 !important;transform:translateX(40px) scale(0.95) !important;transition:opacity .6s cubic-bezier(.22,1,.36,1), transform .6s cubic-bezier(.22,1,.36,1) !important}
.mit-card-reveal.mit-visible{opacity:1 !important;transform:translateX(0) scale(1) !important}
.mit-fade{opacity:0 !important;transition:opacity .8s cubic-bezier(.22,1,.36,1), transform .8s cubic-bezier(.22,1,.36,1) !important;transform:translateY(30px) !important}
.mit-fade.mit-visible{opacity:1 !important;transform:translateY(0) !important}
@keyframes mit-icon-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
.mit-float{animation:mit-icon-float 3s ease-in-out infinite}
.framer-mit-faq-answer{box-sizing:border-box;width:100%}
.framer-mit-faq-answer.open{max-height:240px !important;opacity:1 !important;padding-top:12px !important}
[data-framer-name="FAQ Item"]{cursor:pointer}
@media (prefers-reduced-motion:reduce){.mit-fade,.mit-card-reveal,.mit-float{opacity:1 !important;transform:none !important;animation:none !important}}

.mit-faq-item{box-sizing:border-box}
.mit-faq-item:hover{box-shadow:0 8px 24px rgba(26,31,43,.06)}
.mit-faq-item.open .mit-faq-plus{transform:rotate(45deg)}
.mit-faq-item.open .mit-faq-answer{max-height:220px !important;opacity:1 !important;padding-top:10px !important}


.mit-faq-item.open{z-index:30 !important}
.mit-faq-item.open .mit-faq-row{border-radius:16px 16px 0 0}
</style>
/* ===== RESPONSIVE V2: Fluid scaling + Mobile ===== */
/* Wrapper for scaling */
#fluid-wrapper {
  display: flex;
  justify-content: center;
  overflow: hidden;
  width: 100%;
}
#fluid-wrapper > #main {
  transform-origin: top center;
}

/* ≥1024px: original desktop, centered */
@media (min-width: 1024px) {
  #fluid-wrapper > #main {
    transform: none;
  }
}

/* <1024px: Mobile layout — clean, no white space */
@media (max-width: 1023px) {
  #fluid-wrapper {
    display: none !important;
  }
  #mobile-layout-v2 {
    display: block !important;
    font-family: "Geist", "Geist Placeholder", -apple-system, BlinkMacSystemFont, sans-serif;
    background: #F5F7FA;
    min-height: 100vh;
    color: #1A1F2B;
    overflow-x: hidden;
  }
  .mob-nav{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:#fff;border-bottom:1px solid #e1e8f2;position:sticky;top:0;z-index:100;box-shadow:0 1px 4px rgba(0,0,0,0.04)}
  .mob-brand{display:flex;align-items:center;gap:8px}
  .mob-logo{width:34px;height:34px;background:linear-gradient(135deg,#0d6b6b,#2aabee);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:14px;flex-shrink:0}
  .mob-brand-name{font-weight:700;font-size:16px;color:#1A1F2B}
  .mob-cta-btn{background:linear-gradient(135deg,#0d6b6b,#2aabee);color:#fff;border:none;padding:8px 16px;border-radius:10px;font-weight:600;font-size:13px;cursor:pointer;text-decoration:none;white-space:nowrap}
  .mob-hero{padding:32px 16px 24px;text-align:center;background:#fff}
  .mob-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(22,133,199,0.08);border:1px solid rgba(22,133,199,0.2);border-radius:20px;padding:6px 14px;margin-bottom:16px}
  .mob-badge-dot{width:6px;height:6px;background:#1685C7;border-radius:50%}
  .mob-badge-text{font-weight:600;font-size:13px;color:#1685C7}
  .mob-hero h1{font-size:26px;font-weight:800;line-height:1.2;margin:0 0 12px;color:#1A1F2B}
  .mob-hero-sub{font-size:15px;line-height:1.5;color:#5E6B7F;margin:0 0 24px}
  .mob-hero-actions{display:flex;flex-direction:column;gap:10px;max-width:320px;margin:0 auto}
  .mob-btn-primary{display:block;width:100%;background:linear-gradient(135deg,#0d6b6b,#2aabee);color:#fff;border:none;padding:14px 24px;border-radius:12px;font-weight:700;font-size:15px;text-decoration:none;text-align:center;box-sizing:border-box}
  .mob-btn-secondary{display:block;width:100%;background:#fff;color:#1A1F2B;border:1.5px solid #d1d9e6;padding:14px 24px;border-radius:12px;font-weight:600;font-size:15px;text-decoration:none;text-align:center;box-sizing:border-box}
  .mob-telegram-preview{margin:24px 16px 0;background:#fff;border:1px solid #e1e8f2;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.06)}
  .mob-chat-header{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:#f8fafc;border-bottom:1px solid #e1e8f2}
  .mob-chat-identity{display:flex;align-items:center;gap:8px}
  .mob-chat-avatar{width:32px;height:32px;background:linear-gradient(135deg,#0d6b6b,#2aabee);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:12px}
  .mob-chat-name{font-weight:700;font-size:14px;color:#1A1F2B}
  .mob-chat-status{font-weight:500;font-size:11px;color:#8EA1B2}
  .mob-chat-body{padding:14px}
  .mob-msg-user{background:#EEF2F6;border-radius:12px 12px 4px 12px;padding:10px 14px;font-size:13px;line-height:1.4;color:#1A1F2B;margin-bottom:10px;max-width:85%}
  .mob-msg-bot{background:#fff;border:1px solid #e1e8f2;border-radius:12px 12px 12px 4px;padding:12px 14px;margin-bottom:10px}
  .mob-msg-bot-title{font-weight:700;font-size:13px;color:#1A1F2B;margin-bottom:6px}
  .mob-msg-bot-list{font-size:12px;color:#5E6B7F;line-height:1.6;margin:0;padding:0;list-style:none}
  .mob-chat-input{display:flex;align-items:center;padding:8px 14px;border-top:1px solid #e1e8f2;gap:8px}
  .mob-chat-input-text{flex:1;font-size:12px;color:#8EA1B2}
  .mob-chat-input-mic{width:28px;height:28px;background:#2AABEE;border-radius:50%;flex-shrink:0}
  .mob-result-cards{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:0 14px 14px}
  .mob-result-card{background:#f8fafc;border:1px solid #e1e8f2;border-radius:10px;padding:10px;font-size:12px;font-weight:600;color:#1A1F2B;line-height:1.35}
  .mob-result-card-highlight{background:linear-gradient(135deg,#0d6b6b,#2aabee);color:#fff;border:none;grid-column:1/-1;padding:14px;font-size:18px;font-weight:800;border-radius:10px}
  .mob-result-sub{font-size:12px;font-weight:500;opacity:0.78;margin-top:4px}
  .mob-section{padding:32px 16px}
  .mob-section-alt{background:#fff}
  .mob-section h2{font-size:22px;font-weight:800;line-height:1.2;margin:0 0 8px;color:#1A1F2B}
  .mob-section-sub{font-size:14px;line-height:1.5;color:#5E6B7F;margin:0 0 20px}
  .mob-advantage-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .mob-advantage-card{background:#fff;border:1px solid #e1e8f2;border-radius:12px;padding:16px}
  .mob-advantage-card h3{font-size:16px;font-weight:700;margin:0 0 6px;color:#1A1F2B}
  .mob-advantage-card p{font-size:13px;line-height:1.4;color:#5E6B7F;margin:0}
  .mob-capability-card{background:#fff;border:1px solid #e1e8f2;border-radius:14px;padding:20px;margin-bottom:12px}
  .mob-capability-card h3{font-size:18px;font-weight:800;margin:0 0 8px;color:#1A1F2B}
  .mob-capability-card p{font-size:14px;line-height:1.45;color:#5E6B7F;margin:0}
  .mob-cta-banner{background:linear-gradient(135deg,#0d6b6b,#2aabee);border-radius:16px;padding:28px 20px;text-align:center;color:#fff;margin:0 16px 32px}
  .mob-cta-banner h2{font-size:22px;font-weight:800;margin:0 0 8px;color:#fff}
  .mob-cta-banner p{font-size:14px;line-height:1.5;opacity:0.85;margin:0 0 20px}
  .mob-cta-banner .mob-btn-primary{background:#fff;color:#1A1F2B}
  .mob-integration-item{display:flex;align-items:center;gap:12px;background:#fff;border:1px solid #e1e8f2;border-radius:12px;padding:14px;margin-bottom:8px}
  .mob-integration-icon{width:40px;height:40px;background:#f0f4f8;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
  .mob-integration-name{font-weight:600;font-size:14px;color:#1A1F2B}
  .mob-integration-desc{font-size:12px;color:#5E6B7F}
  .mob-pricing-card{background:#fff;border:1px solid #e1e8f2;border-radius:14px;padding:20px;margin-bottom:12px}
  .mob-pricing-card.featured{border:2px solid #2AABEE;box-shadow:0 4px 20px rgba(42,171,238,0.12)}
  .mob-pricing-name{font-weight:700;font-size:16px;color:#1A1F2B;margin-bottom:4px}
  .mob-pricing-price{font-weight:800;font-size:28px;color:#1A1F2B;margin-bottom:12px}
  .mob-pricing-price span{font-size:14px;font-weight:500;color:#5E6B7F}
  .mob-pricing-features{list-style:none;padding:0;margin:0 0 16px}
  .mob-pricing-features li{font-size:13px;color:#5E6B7F;padding:4px 0;line-height:1.4}
  .mob-pricing-features li::before{content:"✓ ";color:#22c55e;font-weight:700}
  .mob-faq-item{background:#fff;border:1px solid #e1e8f2;border-radius:12px;margin-bottom:8px;overflow:hidden}
  .mob-faq-q{padding:16px;font-weight:600;font-size:15px;color:#1A1F2B;cursor:pointer;display:flex;justify-content:space-between;align-items:center;user-select:none}
  .mob-faq-q::after{content:"+";font-size:20px;color:#8EA1B2;transition:transform 0.2s}
  .mob-faq-item.open .mob-faq-q::after{content:"−"}
  .mob-faq-a{padding:0 16px 16px;font-size:14px;line-height:1.5;color:#5E6B7F;display:none}
  .mob-faq-item.open .mob-faq-a{display:block}
  .mob-form{background:#fff;border-radius:16px;padding:24px 16px;box-shadow:0 4px 24px rgba(0,0,0,0.06)}
  .mob-form h2{font-size:20px;font-weight:800;margin:0 0 8px;text-align:center}
  .mob-form p{font-size:14px;color:#5E6B7F;text-align:center;margin:0 0 20px}
  .mob-form input,.mob-form textarea{width:100%;padding:14px;border:1.5px solid #d1d9e6;border-radius:10px;font-size:15px;font-family:inherit;margin-bottom:12px;box-sizing:border-box;background:#f8fafc;color:#1A1F2B}
  .mob-form input:focus,.mob-form textarea:focus{outline:none;border-color:#2AABEE;background:#fff}
  .mob-form textarea{min-height:100px;resize:vertical}
  .mob-form button{width:100%;background:linear-gradient(135deg,#0d6b6b,#2aabee);color:#fff;border:none;padding:16px;border-radius:12px;font-weight:700;font-size:16px;cursor:pointer}
  .mob-form-status{text-align:center;font-size:13px;margin-top:10px;min-height:18px}
  .mob-form-status.success{color:#22c55e}
  .mob-form-status.error{color:#dc2626}
  .mob-footer{text-align:center;padding:24px 16px;font-size:12px;color:#8EA1B2;border-top:1px solid #e1e8f2}
}
#mobile-layout-v2{display:none}
@media (min-width:1024px){#mobile-layout-v2{display:none!important}}
</head>
